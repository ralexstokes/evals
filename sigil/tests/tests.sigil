(ns some-tests)

(def! assert! (fn* [x msg]
  (if (not x)
    (throw msg))))

(assert! (= 3 (+ 1 2)) :add)
(assert! (= 1/2 (/ 1 2)) :ratio)
(assert! (= :some-tests/a ::a) :autokw)

(def! z 1)
(set! z 2)
(assert! (= z 2) :set)
(assert! (= #'some-tests/z (var z)) :var)

(assert! (= [2 3 4] (map (fn* [x] (+ x 1)) [1 2 3])) :map)
(assert! (= [3 5] (map + [1 2] [2 3])) :map2)
(assert! (= 6 (apply + [1 2 3])) :apply)
(assert! (= '(some-tests/a some-tests/b) `(a b)) :syntax-quote)
(assert! (= [1 2 3 4]
            (let* [[a b & rest :as all] [1 2 3 4]]
              (concat [a b] rest)))
         :vec-destructure)
(assert! (= 7
            (let* [{:keys [x] :or {x 9} :as m} {:x 7}]
              x))
         :map-destructure)
(assert! (= 9
            (let* [{:keys [x] :or {x 9}} {}]
              x))
         :map-default)
(assert! (= 6
            (loop* [n 3 acc 0]
              (if (= n 0)
                acc
                (recur (dec n) (+ acc n)))))
         :loop)

(defmacro unless [pred body]
  `(if ~pred nil ~body))
(assert! (= 5 (unless false 5)) :macro)

(def! a (atom 1))
(reset! a 2)
(assert! (= 2 @a) :atom)
(swap! a + 3)
(assert! (= 5 @a) :swap)

(assert! (= :foo (try* (/ 1 0) (catch e :foo))) :try)

(def! ex-info (fn* [cause data]
                   {:cause cause
                    :data data}))

(def! assert-eq! (fn* [a b]
                      (if (not (= a b))
                        (throw (ex-info "assertion of equality failed" [a b])))))

(def! run-test (fn* [[input-source expected-result]]
                    (let* [result (eval (read-string input-source))]
                          (assert-eq! expected-result result))))

(def! run-suite (fn* [suite]
                     (map run-test suite)))

(def! some-suite [["(+ 1 2)" 3]
                  ["(+ 4 4)" 8]
                  ["(+ 2 3)" 5]
                  ["(let* [x 5] (+ 2 x))" 7]
                  ["(do (def! a 3) (+ a 33))" 36]
                  ["(do (def! inc (fn* [x] (+ x 1))) (inc 4))" 5]
                  ["(if true 1 2)" 1]
                  ["(if nil :a :b)" :b]
                  ["(map (fn* [x] (+ x 1)) [1 2 3])" [2 3 4]]
                  ["(try* (/ 1 0) (catch _ :foo))" :foo]])

(run-suite some-suite)

(def! x 42)
(println "x =" x)
(def! fib (fn* [n]
  (loop* [a 0 b 1 i n]
    (if (= i 0)
      a
      (recur b (+ a b) (dec i))))))

(println "fib(10) =" (fib 10))

(println "1/3 + 1/6 =" (+ 1/3 1/6))

(println :ok)
